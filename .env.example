# Debrief — every environment variable the finished app will ever need.
# Copy to .env and fill in real values ONLY when going live; the entire app runs
# in mock mode (MOCK_MODE=true) with none of these set. .env is gitignored.

# ---------------------------------------------------------------------------
# App mode
# ---------------------------------------------------------------------------
# Mock gating is PER DOMAIN. Each flag defaults to true (fixtures: no network,
# no keys, no cost). Set one to false to take that domain live (its credentials
# below then become required).
MOCK_MODE_F1=true
MOCK_MODE_VALORANT=true
MOCK_MODE_CS2=true

# Legacy GLOBAL override. If set to a non-empty value it wins for every domain,
# ignoring the three flags above (this is what the Vercel MOCK_MODE=true env var
# and older local-dev workflows rely on). Leave UNSET to use the per-domain
# flags. Example: MOCK_MODE=true forces the whole app onto fixtures.
MOCK_MODE=

# mock | cognito. Defaults to following the mock gate; set explicitly to force one.
AUTH_MODE=

# ---------------------------------------------------------------------------
# Grading (Phase 1) — the only paid credential in the stack
# ---------------------------------------------------------------------------
# Anthropic API key for the grading calls.
# Get it: console.anthropic.com -> API Keys.
ANTHROPIC_API_KEY=

# Claude model id used for grading. Defaults to claude-opus-4-8 if unset; the
# grading code shapes the request per model (adaptive thinking vs legacy
# budget_tokens, structured output on/off) so switching this is config-only.
CLAUDE_MODEL=claude-opus-4-8

# ---------------------------------------------------------------------------
# AWS (Phase 1 deploy + Phase 2 accounts/history)
# ---------------------------------------------------------------------------
# Region for all debrief-* resources (Lambda, DynamoDB, Cognito, S3).
AWS_REGION=us-east-1

# Prefix for DynamoDB tables (debrief-users, debrief-attempts,
# debrief-f1-scenarios, debrief-match-cache).
DYNAMODB_TABLE_PREFIX=debrief-

# Cognito user pool (debrief-user-pool) — created in the AWS console or IaC at
# Phase 2 deploy. Pool ID looks like us-east-1_XXXXXXXXX; the client ID comes
# from the pool's "App integration" tab.
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# ---------------------------------------------------------------------------
# VALORANT (Phase 3)
# ---------------------------------------------------------------------------
# HenrikDev API key — the prototyping data source for match/round history.
# Get it: join the HenrikDev Discord (docs.henrikdev.xyz) and request a free key.
HENRIKDEV_API_KEY=

# Official Riot API production credentials — the post-approval replacement for
# HenrikDev. Get them: developer.riotgames.com -> register the product and
# submit the production key application (free, approval-gated; apply once the
# HenrikDev prototype works, per the roadmap).
RIOT_CLIENT_ID=
RIOT_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# CS2 (Phase 4)
# ---------------------------------------------------------------------------
# tracker.gg developer app ID, sent as the TRN-Api-Key header on their official
# CS:GO/CS2 stats API. Get it: tracker.gg/developers -> create an app (free).
TRACKERGG_APP_ID=

# ---------------------------------------------------------------------------
# Local development
# ---------------------------------------------------------------------------
# Port for scripts/local_api.py (the local API Gateway simulator).
DEBRIEF_LOCAL_PORT=8000

# Where the frontend finds the API. Local: the simulator. Deployed: the
# debrief-api API Gateway URL. (Also mirrored in frontend/.env.local.example —
# Next.js reads it from frontend/.env.local.)
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Overrides the repo root used to load scenarios/prompts (rarely needed).
DEBRIEF_DATA_ROOT=
